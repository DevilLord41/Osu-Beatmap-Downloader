<Window x:Class="OsuBmDownloader.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="osu! Beatmap Downloader - Setup"
        Width="520" Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FF1A1A2E">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="osu! Beatmap Downloader" Foreground="#FF66CCFF"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Set up your credentials to get started."
                   Foreground="#FF888888" FontSize="12" Margin="0,0,0,20"/>

        <!-- osu! folder -->
        <TextBlock Grid.Row="2" Foreground="#FFCCCCCC" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,2">
            <Run Text="1." Foreground="#FF66CCFF"/> <Run Text="osu! Installation Folder"/>
        </TextBlock>
        <TextBlock Grid.Row="2" Foreground="#FF777777" FontSize="10" Margin="0,20,0,0">
            Select your osu! folder (e.g. D:\osu!). The app will read Songs from it.
        </TextBlock>
        <DockPanel Grid.Row="3" Margin="0,0,0,16">
            <Button DockPanel.Dock="Right" Content="Browse..." Click="BrowseFolder_Click"
                    Background="#FF3D3D5C" Foreground="White" Padding="12,6"
                    BorderThickness="0" Cursor="Hand" Margin="8,0,0,0" FontSize="12"/>
            <TextBox x:Name="OsuFolderBox"
                     Background="#FF252540" Foreground="White" BorderBrush="#FF444466"
                     Padding="8,6" FontSize="12" IsReadOnly="True"/>
        </DockPanel>

        <!-- API credentials -->
        <TextBlock Grid.Row="4" Foreground="#FFCCCCCC" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6">
            <Run Text="2." Foreground="#FF66CCFF"/> <Run Text="osu! API Credentials"/>
        </TextBlock>
        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Foreground="#FF777777" FontSize="11" TextWrapping="Wrap" LineHeight="18">
                <Run Text="1."/> Open <Hyperlink NavigateUri="https://osu.ppy.sh/home/account/edit" RequestNavigate="Hyperlink_Navigate" Foreground="#FF66CCFF">osu.ppy.sh/home/account/edit</Hyperlink>
                <LineBreak/><Run Text="2."/> Go to OAuth and click "New OAuth Application"
                <LineBreak/><Run Text="3."/> App name: <Run FontWeight="SemiBold" Foreground="#FFAAAAAA">OsuBMDownloader</Run>
                <LineBreak/><Run Text="4."/> Callback URL:
            </TextBlock>
            <TextBox Text="http://localhost:7270/callback" IsReadOnly="True"
                     Background="#FF252540" Foreground="#FF66CCFF" BorderBrush="#FF444466"
                     Padding="6,4" FontSize="11" Margin="20,4,0,4"
                     HorizontalAlignment="Left" Width="260"/>
            <TextBlock Foreground="#FF777777" FontSize="11">
                <Run Text="5."/> Copy both Client ID and Client Secret below.
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="6" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Client ID" Foreground="#FFAAAAAA"
                       FontSize="11" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="2" x:Name="ClientIdBox"
                     Background="#FF252540" Foreground="White" BorderBrush="#FF444466"
                     Padding="8,5" FontSize="12"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Client Secret" Foreground="#FFAAAAAA"
                       FontSize="11" VerticalAlignment="Center"/>
            <PasswordBox Grid.Row="2" Grid.Column="2" x:Name="ClientSecretBox"
                         Background="#FF252540" Foreground="White" BorderBrush="#FF444466"
                         Padding="8,5" FontSize="12"/>
        </Grid>

        <TextBlock Grid.Row="7" Foreground="#FF666666" FontSize="10" Margin="0,0,0,4" TextWrapping="Wrap">
            Free users: 60 downloads/hour, no preview audio. osu! Supporters get unlimited access.
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click"
                    Background="#FF3D3D5C" Foreground="White"
                    Padding="24,8" Cursor="Hand" BorderThickness="0" FontSize="13" Margin="0,0,8,0"/>
            <Button Content="Save" Click="Save_Click"
                    Background="#FF66CCFF" Foreground="#FF1A1A2E" FontWeight="Bold"
                    Padding="24,8" Cursor="Hand" BorderThickness="0" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
